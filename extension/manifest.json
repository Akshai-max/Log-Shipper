{
  "manifest_version": 3,
  "name": "Activity Logger",
  "version": "1.0",
  "description": "Logs browser activity (tab switching, navigation, time spent) and sends to a configured Admin Server.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "identity",
    "identity.email",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
